; --- 投影看板 系統設定檔 ---
; 提示：修改後請重啟系統以套用變更

[System]

; 頁面自動重新整理的時間（秒）
refresh_seconds = 60

[Display]
; 自動捲動一格的間隔時間（毫秒，1000 = 1秒）
scroll_speed_ms = 3000

;看板表格中日期顯示格式 0 僅日期 1 已停留時間

date_format = 1

[Workflow]
; 階段定義：ID:顯示名稱 (以逗號分隔)
stages = ORDER:訂貨, ARRIVAL:到貨, PRODUCTION:製作, DELIVERY:出庫
; 初始階段 ID
initial_stage = ORDER
